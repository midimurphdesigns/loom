# Anthropic — required for any LLM step
ANTHROPIC_API_KEY=

# Stripe — test mode only. Webhook secret comes from `stripe listen --forward-to`
# output when developing locally.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Upstash Redis — used for workflow state, idempotency keys, daily cost cap,
# Stripe webhook event persistence. Without these set, everything degrades to
# in-memory which only works in single-process local dev.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Daily USD cap on all Anthropic spend. Conservative default protects the
# build budget; raise when actively iterating.
LOOM_DAILY_USD_CAP=2

# Agent spending authority — hard ceilings the LLM cannot exceed regardless
# of prompt content. Validated AFTER the LLM returns its decision, BEFORE
# the side-effecting step executes.
LOOM_MAX_DISCOUNT_USD=25
LOOM_MAX_REFUND_USD=50

# Owner-bypass cookie for rate-limit testing (set to a long random string)
LOOM_ADMIN_KEY=
